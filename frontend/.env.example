# AutoMint Frontend Environment Variables
# Copy to .env.local and fill in deployed contract addresses

# Network: TESTNET or MAINNET
NEXT_PUBLIC_NETWORK=TESTNET

# Stellar Soroban RPC endpoint
NEXT_PUBLIC_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Deployed contract addresses (set by deploy.sh or manually after deployment)
NEXT_PUBLIC_REGISTRY_CONTRACT=CCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCC01
NEXT_PUBLIC_BOT_NFT_CONTRACT=CCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCC02
NEXT_PUBLIC_ACCRUAL_CONTRACT=CCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCC03
NEXT_PUBLIC_MARKETPLACE_CONTRACT=CCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCC04
NEXT_PUBLIC_TOKEN_CONTRACT=CCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCC05
