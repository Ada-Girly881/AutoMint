# AutoMint frontend environment variables
# Copy this file to .env.local and replace each placeholder with the
# values from the target Soroban deployment.

# Public network label shown by the frontend (for example: TESTNET or MAINNET).
NEXT_PUBLIC_NETWORK=TESTNET

# Soroban RPC endpoint used for transaction simulation and submission.
NEXT_PUBLIC_SOROBAN_RPC_URL=https://your-soroban-rpc.example.com

# Stellar network passphrase used when signing transactions.
NEXT_PUBLIC_STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"

# Registry contract ID for bot ownership and metadata lookup.
NEXT_PUBLIC_REGISTRY_CONTRACT_ID=CCXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX01

# Bot NFT contract ID for minting and reading bot NFT data.
NEXT_PUBLIC_BOT_NFT_CONTRACT_ID=CCXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX02

# Accrual contract ID for points accrual and claim operations.
NEXT_PUBLIC_ACCRUAL_CONTRACT_ID=CCXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX03

# Marketplace contract ID for listing, buying, and canceling bot sales.
NEXT_PUBLIC_MARKETPLACE_CONTRACT_ID=CCXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX04

# Token contract ID for the in-app payment/reward asset.
NEXT_PUBLIC_TOKEN_CONTRACT_ID=CCXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX05
